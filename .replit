modules = ["nodejs-20", "python-3.12", "web", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "postgresql", "rustc"]

[userenv]

[userenv.shared]
CORS_ORIGINS = "*"
JWT_SECRET = "replit-ollcollab-jwt-secret-2024"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && PORT=5000 BROWSER=none npm start"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && python3 -m uvicorn server:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd backend && python3 -m uvicorn server:app --host 0.0.0.0 --port 5000"]
build = ["bash", "-c", "pip install -r backend/requirements.txt && cd frontend && npm install --legacy-peer-deps && npm run build"]
